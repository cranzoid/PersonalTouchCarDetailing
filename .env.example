# Copy to .env.local and fill in. Never commit real values.

# PostgreSQL connection. Dev default uses the local unix-socket server.
DATABASE_URL=postgres://localhost/ptcd_dev?host=/tmp

# Used by tests (see tests/). Kept separate so tests can truncate tables.
TEST_DATABASE_URL=postgres://localhost/ptcd_test?host=/tmp

# 32+ random bytes, e.g. `openssl rand -hex 32`. Salts privacy-sensitive
# one-way fingerprints (session and portal tokens are independently random
# and stored only as hashes).
SESSION_SECRET=change-me

# Required only when seeding the first staff owner in production. The seed
# command refuses to create the public development credential in production.
# SEED_ADMIN_NAME=Owner
# SEED_ADMIN_EMAIL=owner@your-domain.example
# SEED_ADMIN_PASSWORD=

# Payment provider (Phase 4). Leave unset in dev — FakePaymentProvider is used.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Messaging providers (Phase 5). Unset in dev — messages are logged to DB/console.
# In production, email requires both RESEND_API_KEY and EMAIL_FROM, and SMS
# requires all three Twilio values. Missing production configuration records a
# failed communication instead of pretending that it was delivered.
# RESEND_API_KEY=
# EMAIL_FROM=Personal Touch Car Detailing <bookings@your-domain.example>
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+19055550143
# MESSAGING_MODE=log # optional explicit log-only mode for staging

# Private customer photo storage. Local development uses var/uploads when
# these are unset. Production refuses local-disk uploads; configure any
# S3-compatible service (AWS S3, Cloudflare R2, Backblaze B2, etc.).
# OBJECT_STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# OBJECT_STORAGE_BUCKET=personal-touch-private
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY_ID=
# OBJECT_STORAGE_SECRET_ACCESS_KEY=

# Azure Blob Storage alternative. In Azure App Service, set the account and
# container names and grant the app's managed identity Storage Blob Data
# Contributor. AZURE_STORAGE_CONNECTION_STRING is only needed for local
# development or environments without managed identity.
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_CONTAINER_NAME=private-files
# AZURE_STORAGE_CONNECTION_STRING=

# Base URL used to build links in outbound emails/SMS (portal links, etc).
# APP_BASE_URL=https://your-production-domain.example

# Scheduled-task endpoint (/api/cron/tick). Required in production if you want
# overdue invoices / Phase 5 reminders to run on a timer, not just on-read.
# Point any external scheduler at it with `Authorization: Bearer $CRON_SECRET`.
# CRON_SECRET=
